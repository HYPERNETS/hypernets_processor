[Site_specific]
site_id = GHNA
offset_pan=
offset_tilt=
use_config_latlon=
lat=
lon=
azimuth_switch=
angle2use= pt_ask

[Site_specific_QC]
deployment_periods = [{"start_date": "2021-11-18" , "stop_date": "2022-05-05" ,"HYPSTAR_SN": 220251, "valid": False, "comments": "v1 instrument, winter data too heterogenious"}, {"start_date": "2022-05-05" , "stop_date": "2022-10-11" ,"HYPSTAR_SN": 220251, "valid": True, "comments": "v1 instrument, summer"} ,{"start_date": "2022-10-11" , "stop_date": "2023-04-29" ,"HYPSTAR_SN": 220251, "valid": False, "comments": "v1 instrument,  winter data too heterogenious"} ,{"start_date": "2023-04-29" , "stop_date": "2023-11-01" ,"HYPSTAR_SN": 220251, "valid": True, "comments": "v1 instrument, summer"}, {"start_date": "2023-11-01" , "stop_date": "2024-06-26" ,"HYPSTAR_SN": 220251, "valid": False, "comments": "v1 instrument, winter data too heterogenious"},{"start_date": "2024-06-26" , "stop_date": "present" ,"HYPSTAR_SN": 222314, "valid": False, "comments": "v3 instrument, too few clear-sky measurements for reliable QC"}]
bad_dates_period = [None, None, None, None, None, None]
limit_tod_period = [None, None, None, None, None, None]
bad_sequences_period = [[], [], [], [], [], []] # list (periods) of list with strings with bad sequence IDs
max_sza_period = [60,50,60,60,60,60]
bad_viewing_angles_period = [[(0, "all"),(5, "all"),(10, "all"), ("all", "<70"), ("all", ">300")], [(0, "all"),(5, "all"),(10, "all"), ("all", "<70"), ("all", ">300")],[(0, "all"),(5, "all"),(10, "all"), ("all", "<70"), ("all", ">300")],[(0, "all"),(5, "all"),(10, "all"), ("all", "<70"), ("all", ">300")],[(0, "all"),(5, "all"),(10, "all"), ("all", "<70"), ("all", ">300")],[(0, "all"),(5, "all"),(10, "all"), ("all", "<70"), ("all", ">300")]] # list (periods) of list of tuples where each tuple is a (vza,vaa) pair to mask ("all" indicates all angles of that type should be masked)
bad_solar_angles_period = [[], [], [],[], [], []] # list (periods) of list of tuples where each tuple is a (vza,vaa) pair to mask ("all" indicates all angles of that type should be masked)
bad_relative_angles_period = [[("sza", 0),("sza", 360)], [("sza", 0),("sza", 360)], [("sza", 0),("sza", 360)],[("sza", 0),("sza", 360)], [("sza", 0),("sza", 360)], [("sza", 0),("sza", 360)]] # list (periods) of list of tuples where each tuple is a (vza,vaa) pair to mask ("sza" indicates all angles smaller than sza will be selected)
angle_tolerance=1
raa_angle_tolerance = 10
bad_wavelengths_period = [[], [], [], [], [], []] # list (periods) of list(multiple wavelength ranges) of list(bad_start_Wav,bad_end_wav)
postprocessing_qc_file_period = [None,"WWUK_2022May_2022Oct_bounds.nc",None,"WWUK_2023Apr_2023Nov_bounds.nc",None,None] # list of strings to filenames from separate post-processing analysis
misalignment_vza=[None,0.3097,None,1.5809,None,None]
misalignment_vza_unc=[None,0.3442,None,0.1928,None,None]
misalignment_vaa=[None,-137.035,None,-163.678,None,None]
misalignment_vaa_unc=[None,107.592,None,3.086,None,None]
misalignment_corr=[None,1.00207,None,1.01611,None,None]
misalignment_corr_unc=[None,0.00186,None,0.00926,None,None]
apply_site_specific_cloud_check = True


[Processor]
archive_directory= 
network= l
version= 2.2
mcsteps= 100
max_level= L2B
reprocess_from =
uncertainty_l1a= False
bad_wavelength_ranges= 757.5-767.5, 1350-1390
verbose=
delay_hours=

[Databases]
metadata_db_url=
archive_db_url=
anomaly_db_url=
to_archive= True

[Metadata]
comment=
creator_name= Pieter De Vis
creator_email= pieter.de.vis@npl.co.uk
responsible_party= National Physical Laboratory (NPL), UK

[Reading]
model= series_rep,series_id,vaa,azimuth_ref,vza,mode,action,it,scan_total,series_time

[Quality]
l0_threshold=
l0_discontinuity=10000
bad_pointing_threshold_zenith=3
bad_pointing_threshold_azimuth=3
irradiance_zenith_treshold=2
n_valid_irr=5
n_valid_rad=5
n_valid_dark=3
irr_variability_percent=10
clear_sky_check=True
vnir_swir_discontinuity_percent=25

[Calibration]
hypstar_cal_number =
measurement_function_calibrate = StandardMeasurementFunction
calibration_interpolation_method = previous
calibration_file_version = 2.4

[CombineSWIR]
combine_lim_wav= 1000
measurement_function_combine= StepCombine

[Interpolate]
measurement_function_interpolate_time= InterpolationTimeLinearCoscorrected
measurement_function_interpolate_wav= InterpolationWavLinear

[SurfaceReflectance]
measurement_function_surface_reflectance= LandNetworkProtocol

[Output]
product_format= netcdf
remove_vars_strings=
remove_vars_strings_l2=
write_l0a= True
write_l0b= True
write_l1a= True
write_l1b= True
write_l1c= True
write_l2a= True
write_l2b= True
write_l1d= True

[Plotting]
plotting_format= png
plot_fontsize= 14
plot_legendfontsize= 14
plot_l0= False
plot_l1a= False
plot_l1a_diff= False
plot_l1b= True
plot_l1c= False
plot_l2a= True
plot_l2b= True
plot_l1d= True
plot_uncertainty= True
plot_correlation= False
plot_clear_sky_check= True
plot_polar_wav= 900
plot_polar_min=
plot_polar_max=
plot_polar_ndvi= True
