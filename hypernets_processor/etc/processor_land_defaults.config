[Site_specific]
site_id = GHNA
offset_pan=
offset_tilt=
use_config_latlon=
lat=
lon=
azimuth_switch=
angle2use= pt_ask

[Site_specific_QC]
deployment_periods = [{"start_date": "2022-05-17" , "stop_date": "2023-10-17" ,"HYPSTAR_SN": 220261, "comments": "v1 instrument"},{"start_date": "2023-10-20" , "stop_date": "2024-05-23" ,"HYPSTAR_SN": 222316, "comments": "v3 instrument"},{"start_date": "2024-05-24" , "stop_date": "present" ,"HYPSTAR_SN": 222316, "comments": "instrument cleaned and realigned but not replaced/calibrated"}]
bad_dates_period = [None, None, None]
limit_tod_period = [["00:00","14:00"], ["00:00","14:00"], ["00:00","14:00"]]
bad_sequences_period = [[], [], []] # list (periods) of list with strings with bad sequence IDs
bad_viewing_angles_period = [[(0, "all"),(5, "all")], [(0, "all"),(5, "all")], [(0, "all"),(5, "all")]] # list (periods) of list of tuples where each tuple is a (vza,vaa) pair to mask ("all" indicates all angles of that type should be masked)
bad_solar_angles_period = [[], [], []] # list (periods) of list of tuples where each tuple is a (vza,vaa) pair to mask ("all" indicates all angles of that type should be masked)
bad_relative_angles_period = [[("sza", 0),("sza", 360)], [], []] # list (periods) of list of tuples where each tuple is a (vza,vaa) pair to mask ("sza" indicates all angles smaller than sza will be selected)
angle_tolerance=1
raa_angle_tolerance = 10
bad_wavelengths_period = [[], [], []] # list (periods) of list(multiple wavelength ranges) of list(bad_start_Wav,bad_end_wav)
postprocessing_qc_file_period = ["GHNA_2022May_2023Oct.nc","GHNA_2023Oct_2024May.nc","GHNA_2024May_2025Apr.nc"] # list of strings to filenames from separate post-processing analysis
misalignment_vza=[0.69, 1.76, 1.59]
misalignment_vza_unc=[0.04,0.04, 0.03]
misalignment_vaa=[91,-80, -77]
misalignment_vaa_unc=[7, 3, 2]
apply_site_specific_cloud_check = True
reprocess_anomalies=True

[Processor]
archive_directory= 
network= l
version= 2.2
mcsteps= 100
max_level= L2B
reprocess_from =
uncertainty_l1a= False
bad_wavelength_ranges= 757.5-767.5, 1350-1390
verbose=
delay_hours=

[Databases]
metadata_db_url=
archive_db_url=
anomaly_db_url=
to_archive= True

[Metadata]
comment=
creator_name= Pieter De Vis
creator_email= pieter.de.vis@npl.co.uk
responsible_party= National Physical Laboratory (NPL), UK

[Reading]
model= series_rep,series_id,vaa,azimuth_ref,vza,mode,action,it,scan_total,series_time

[Quality]
l0_threshold=
l0_discontinuity=10000
bad_pointing_threshold_zenith=3
bad_pointing_threshold_azimuth=3
irradiance_zenith_treshold=2
n_valid_irr=5
n_valid_rad=5
n_valid_dark=3
irr_variability_percent=10
clear_sky_check=True
vnir_swir_discontinuity_percent=25

[Calibration]
hypstar_cal_number =
measurement_function_calibrate = StandardMeasurementFunction
calibration_interpolation_method = previous
calibration_file_version = 2.3

[CombineSWIR]
combine_lim_wav= 1000
measurement_function_combine= StepCombine

[Interpolate]
measurement_function_interpolate_time= InterpolationTimeLinearCoscorrected
measurement_function_interpolate_wav= InterpolationWavLinear

[SurfaceReflectance]
measurement_function_surface_reflectance= LandNetworkProtocol

[Output]
product_format= netcdf
remove_vars_strings=
remove_vars_strings_l2=
write_l0a= True
write_l0b= True
write_l1a= True
write_l1b= True
write_l1c= True
write_l2a= True
write_l2b= True
write_l1d= True

[Plotting]
plotting_format= png
plot_fontsize= 14
plot_legendfontsize= 14
plot_l0= False
plot_l1a= False
plot_l1a_diff= False
plot_l1b= True
plot_l1c= False
plot_l2a= True
plot_l2b= True
plot_l1d= True
plot_uncertainty= True
plot_correlation= False
plot_clear_sky_check= True
plot_polar_wav= 900
plot_polar_min=
plot_polar_max=
plot_polar_ndvi= True
